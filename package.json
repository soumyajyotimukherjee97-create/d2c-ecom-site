{
  "name": "d2c-ecom-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -F storefront dev",
    "dev:internal": "pnpm -F internal dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:integration": "pnpm -F storefront test:integration",
    "e2e": "pnpm -F storefront e2e",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > apps/storefront/src/lib/supabase/types.ts"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "supabase": "^2.91.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver",
      "supabase"
    ]
  }
}
